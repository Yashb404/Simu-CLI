# Required runtime configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/cli_demo_studio
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_hex_chars
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# Optional overrides
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3001
PORT=3001
RATE_LIMIT_REQUESTS_PER_MINUTE=100
DB_MAX_CONNECTIONS=5
SESSION_TIMEOUT_DAYS=7
SESSION_COOKIE_SECURE=false
RUST_LOG=server=info,tower_sessions=info

# Local frontend dev uses crates/app/Trunk.toml proxies so /api and /auth routes
# from :8080 are forwarded to backend on :3001.
